# Copy this file to `.env` and fill in your Supabase project values.
# Get them from: Supabase Dashboard → Project Settings → API
#
# IMPORTANT: Never commit your real `.env` file to GitHub.
# `.gitignore` already blocks `.env` — keep it that way.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_or_publishable_key

# Optional aliases for server-side tooling
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_anon_or_publishable_key

# Optional — local admin/e2e scripts only. Never expose to the browser.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
